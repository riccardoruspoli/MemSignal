<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F7FAFD" Offset="0" />
        <GradientStop Color="#EEF5F9" Offset="0.55" />
        <GradientStop Color="#F9FBFD" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="TopBarBackgroundBrush" Color="#F9FBFD" />
    <SolidColorBrush x:Key="PanelBrush" Color="#F9FBFD" />
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="#EEF3F8" />
    <SolidColorBrush x:Key="SurfacePressedBrush" Color="#E5ECF4" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#111827" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#5F6875" />
    <SolidColorBrush x:Key="DividerBrush" Color="#D9E0E8" />
    <SolidColorBrush x:Key="FocusBrush" Color="#2563EB" />
    <SolidColorBrush x:Key="ThresholdGreenBrush" Color="#22A53B" />
    <SolidColorBrush x:Key="ThresholdYellowBrush" Color="#F5C542" />
    <SolidColorBrush x:Key="ThresholdRedBrush" Color="#E53935" />
    <SolidColorBrush x:Key="ThresholdSeparatorBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ThresholdMarkerFillBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ThresholdMarkerStrokeBrush" Color="#1F2937" />
    <SolidColorBrush x:Key="ThresholdLabelBrush" Color="#4B5563" />
</ResourceDictionary>
