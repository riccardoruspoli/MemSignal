<Window x:Class="MemSignal.App.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MemSignal.App.Wpf"
        Title="MemSignal"
        Icon="Assets\app-icon.png"
        Width="560"
        Height="760"
        MinWidth="460"
        MinHeight="620"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="CommandButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SurfacePressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{DynamicResource FocusBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MetricNameText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,8" />
        </Style>

        <Style x:Key="MetricValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,8" />
        </Style>

        <Style x:Key="DetailsExpander" TargetType="Expander">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border BorderBrush="{DynamicResource DividerBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Background="{DynamicResource PanelBrush}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <ToggleButton x:Name="HeaderSite"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Padding="16,0"
                                              MinHeight="44"
                                              HorizontalAlignment="Stretch"
                                              HorizontalContentAlignment="Stretch"
                                              VerticalContentAlignment="Center"
                                              Cursor="Hand">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="HeaderBackground"
                                                    Background="Transparent"
                                                    MinHeight="{TemplateBinding MinHeight}"
                                                    HorizontalAlignment="Stretch"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                  VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="HeaderBackground" Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="HeaderBackground" Property="Background" Value="{DynamicResource SurfacePressedBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsKeyboardFocused" Value="True">
                                                    <Setter TargetName="HeaderBackground" Property="BorderBrush" Value="{DynamicResource FocusBrush}" />
                                                    <Setter TargetName="HeaderBackground" Property="BorderThickness" Value="1" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                    <Grid VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Path x:Name="Chevron"
                                              Width="10"
                                              Height="6"
                                              Margin="0,0,14,0"
                                              VerticalAlignment="Center"
                                              Stroke="{DynamicResource TextPrimaryBrush}"
                                              StrokeThickness="1.75"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Data="M 1 1 L 5 5 L 9 1"
                                              RenderTransformOrigin="0.5,0.5">
                                            <Path.RenderTransform>
                                                <RotateTransform Angle="0" />
                                            </Path.RenderTransform>
                                        </Path>
                                        <ContentPresenter Grid.Column="1"
                                                          ContentSource="Header"
                                                          VerticalAlignment="Center"
                                                          RecognizesAccessKey="True" />
                                    </Grid>
                                </ToggleButton>
                                <Border Grid.Row="1"
                                        x:Name="ContentSite"
                                        BorderBrush="{DynamicResource DividerBrush}"
                                        BorderThickness="0,1,0,0"
                                        Visibility="Collapsed">
                                    <ContentPresenter Margin="16,14,16,18" />
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Chevron" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="180" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,0,0,1"
                Background="{DynamicResource TopBarBackgroundBrush}">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Style="{StaticResource CommandButton}"
                        Click="OnRefreshClicked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Refresh"
                                   Margin="8,0,0,0"
                                   FontSize="14"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button x:Name="ThemeButton"
                        Grid.Column="2"
                        Style="{StaticResource CommandButton}"
                        Click="OnThemeClicked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="ThemeIcon"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="ThemeLabel"
                                   Margin="8,0,0,0"
                                   FontSize="14"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <ScrollViewer x:Name="MainScrollViewer"
                      Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,24"
                        MaxWidth="960">
                <TextBlock Text="{Binding ScoreText}"
                           Margin="0,0,0,0"
                           FontSize="78"
                           FontWeight="Bold"
                           Foreground="{Binding StateBrush}"
                           HorizontalAlignment="Center" />

                <TextBlock Text="{Binding ClassificationText}"
                           Margin="0,0,0,0"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{Binding StateBrush}"
                           HorizontalAlignment="Center" />

                <TextBlock Text="{Binding StatusMessage}"
                           Margin="0,8,0,24"
                           FontSize="14"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           MaxWidth="430" />

                <local:ThresholdBar Value="{Binding ScorePercent}"
                                    ModerateThreshold="{Binding ModerateThreshold}"
                                    ElevatedThreshold="{Binding ElevatedThreshold}"
                                    GreenBrush="{DynamicResource ThresholdGreenBrush}"
                                    YellowBrush="{DynamicResource ThresholdYellowBrush}"
                                    RedBrush="{DynamicResource ThresholdRedBrush}"
                                    SeparatorBrush="{DynamicResource ThresholdSeparatorBrush}"
                                    MarkerFillBrush="{DynamicResource ThresholdMarkerFillBrush}"
                                    MarkerStrokeBrush="{DynamicResource ThresholdMarkerStrokeBrush}"
                                    LabelBrush="{DynamicResource ThresholdLabelBrush}"
                                    Height="58"
                                    Margin="0,0,0,24" />

                <TextBlock Text="{Binding LastUpdatedText}"
                           Margin="0,0,0,24"
                           FontSize="14"
                           Foreground="{DynamicResource TextSecondaryBrush}" />

                <Expander Header="Details"
                          IsExpanded="False"
                          Style="{StaticResource DetailsExpander}">
                    <StackPanel>
                        <TextBlock Text="Components"
                                   FontWeight="SemiBold"
                                   FontSize="16"
                                   Margin="0,2,0,8" />
                        <ItemsControl ItemsSource="{Binding ComponentRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="1" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   Style="{StaticResource MetricNameText}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Value}"
                                                   Style="{StaticResource MetricValueText}" />
                                        <Border Grid.Row="1"
                                                Grid.ColumnSpan="2"
                                                Background="{DynamicResource DividerBrush}"
                                                Opacity="0.75" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Raw Metrics"
                                   FontWeight="SemiBold"
                                   FontSize="16"
                                   Margin="0,20,0,8" />
                        <ItemsControl ItemsSource="{Binding RawMetricRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="1" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   Style="{StaticResource MetricNameText}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Value}"
                                                   Style="{StaticResource MetricValueText}" />
                                        <Border Grid.Row="1"
                                                Grid.ColumnSpan="2"
                                                Background="{DynamicResource DividerBrush}"
                                                Opacity="0.75" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
